#!/usr/bin/env bash
# crq — CodeRabbit review queue.
# Account-wide, cross-host coordinator so many parallel agents don't compete for
# one shared (per-developer / per-org) CodeRabbit PR-review rate limit.
#
# All shared state lives on GitHub (works across machines):
#   - an atomic lock ref      refs/heads/$CRQ_LOCK_REF   in $CRQ_REPO
#   - a dashboard issue       $CRQ_ISSUE                  in $CRQ_REPO (queue + status JSON)
#   - a calibration PR        $CRQ_CAL_PR                 in $CRQ_REPO (where we ask "rate limit")
#
# Requires: bash, gh (authenticated), jq. No python required.
# Docs: https://github.com/kristofferR/coderabbit-queue
set -uo pipefail

CRQ_VERSION="1.0.0"

# ----------------------------------------------------------------------------
# Config (env, overridable). A config file is sourced first if present.
# ----------------------------------------------------------------------------
# shellcheck source=/dev/null
[ -f "${CRQ_CONFIG:-$HOME/.config/crq/env}" ] && . "${CRQ_CONFIG:-$HOME/.config/crq/env}"

CRQ_REPO="${CRQ_REPO:-}"                 # owner/name holding lock + dashboard + calibration PR
CRQ_ISSUE="${CRQ_ISSUE:-}"              # dashboard issue number
CRQ_CAL_PR="${CRQ_CAL_PR:-}"           # calibration PR number
CRQ_SCOPE="${CRQ_SCOPE:-${CRQ_REPO%%/*}}"   # comma-list of owners/orgs = rate-limit buckets
CRQ_REPOS="${CRQ_REPOS:-}"; CRQ_REPOS="${CRQ_REPOS// /}"        # autoreview allowlist (owner/name,…); empty = all repos in scope
CRQ_EXCLUDE="${CRQ_EXCLUDE:-}"; CRQ_EXCLUDE="${CRQ_EXCLUDE// /}" # autoreview denylist (owner/name,…)
CRQ_TZ="${CRQ_TZ:-}"                         # dashboard display timezone (IANA, e.g. Europe/Oslo); empty = UTC
CRQ_BOT="${CRQ_BOT:-coderabbitai[bot]}"
CRQ_REVIEW_CMD="${CRQ_REVIEW_CMD:-@coderabbitai review}"
CRQ_RATELIMIT_CMD="${CRQ_RATELIMIT_CMD:-@coderabbitai rate limit}"
CRQ_RL_MARKER="${CRQ_RL_MARKER:-rate limited by coderabbit.ai}"
CRQ_CAL_REPLY_MARKER="${CRQ_CAL_REPLY_MARKER:-auto-generated reply by CodeRabbit}"
CRQ_CALIBRATE_TTL="${CRQ_CALIBRATE_TTL:-120}"
CRQ_LOCK_TTL="${CRQ_LOCK_TTL:-180}"
CRQ_LOCK_TRIES="${CRQ_LOCK_TRIES:-40}"      # max acquire attempts before giving up
CRQ_LOCK_BACKOFF_MAX="${CRQ_LOCK_BACKOFF_MAX:-8}"    # cap (s) on exponential backoff
CRQ_MIN_INTERVAL="${CRQ_MIN_INTERVAL:-90}"
CRQ_INFLIGHT_TIMEOUT="${CRQ_INFLIGHT_TIMEOUT:-900}"
CRQ_POLL="${CRQ_POLL:-15}"
CRQ_WAIT_TIMEOUT="${CRQ_WAIT_TIMEOUT:-0}"   # 0 = no timeout
CRQ_LOCK_REF="${CRQ_LOCK_REF:-crq-lock}"
CRQ_WARNING_SCAN="${CRQ_WARNING_SCAN:-1}"   # 1 = corroborate with open-PR WARNING comments
CRQ_GC_TTL="${CRQ_GC_TTL:-120}"             # min seconds between closed-PR queue prunes
CRQ_AUTOREVIEW_POLL="${CRQ_AUTOREVIEW_POLL:-60}"   # `crq autoreview` poll interval (s)
CRQ_HOST="${CRQ_HOST:-$(hostname 2>/dev/null || echo unknown)}"

EMPTY_TREE="4b825dc642cb6eb9a060e54bf8d69288fbee4904"   # universal empty-tree object
STATE_BEGIN="<!-- crq:state"
STATE_END="-->"

# ----------------------------------------------------------------------------
# Small helpers
# ----------------------------------------------------------------------------
log()  { printf 'crq: %s\n' "$*" >&2; }
die()  { printf 'crq: %s\n' "$*" >&2; exit 1; }
need() { [ -n "${!1:-}" ] || die "$1 is not set (run 'crq init' or set it in ${CRQ_CONFIG:-$HOME/.config/crq/env})"; }

# ISO8601 (e.g. 2026-06-21T20:32:46Z) -> epoch. GNU date, BSD date fallback.
iso2epoch() {
  local s="$1"
  date -u -d "$s" +%s 2>/dev/null && return 0
  s="$(printf '%s' "$s" | sed -E 's/\.[0-9]+//; s/Z?$//')Z"
  date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$s" +%s 2>/dev/null
}
epoch2iso() { date -u -r "$1" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u -d "@$1" +%Y-%m-%dT%H:%M:%SZ; }

# GitHub server time, sampled once per process; thereafter local clock + offset
# (skew-free comparisons across hosts without an API call every time).
_TIME_OFFSET=""
_server_epoch() {
  local h
  h="$(gh api -i / 2>/dev/null | awk -F': ' 'tolower($1)=="date"{sub(/\r$/,"",$2);print $2; exit}')"
  [ -n "$h" ] || { date -u +%s; return; }
  date -u -d "$h" +%s 2>/dev/null && return 0
  date -j -u -f "%a, %d %b %Y %H:%M:%S GMT" "$h" +%s 2>/dev/null && return 0
  date -u +%s
}
now() {
  if [ -z "$_TIME_OFFSET" ]; then
    local s l; s="$(_server_epoch)"; l="$(date -u +%s)"; _TIME_OFFSET=$(( s - l ))
  fi
  echo $(( $(date -u +%s) + _TIME_OFFSET ))
}
now_iso() { epoch2iso "$(now)"; }

# Parse a "...available in 1 hour 13 minutes 10 seconds..." fragment relative to
# a base epoch. Echoes the reset epoch, or nothing if no match.
parse_available_in() {
  local text="$1" base="$2" frag h m s
  frag="$(printf '%s' "$text" | sed -n 's/.*available in \([^.]*\)\..*/\1/p' | head -1)"
  [ -n "$frag" ] || return 1
  h="$(printf '%s' "$frag" | grep -oE '[0-9]+ *hour'   | grep -oE '[0-9]+' | head -1)"; h=${h:-0}
  m="$(printf '%s' "$frag" | grep -oE '[0-9]+ *minute' | grep -oE '[0-9]+' | head -1)"; m=${m:-0}
  s="$(printf '%s' "$frag" | grep -oE '[0-9]+ *second' | grep -oE '[0-9]+' | head -1)"; s=${s:-0}
  echo $(( base + h*3600 + m*60 + s ))
}

# ----------------------------------------------------------------------------
# Distributed lock: atomic create of refs/heads/$CRQ_LOCK_REF.
# Ownership is proven by a nonce read back from the lock commit message, which
# defeats steal races (a loser never deletes the winner's fresh lock).
# ----------------------------------------------------------------------------
_lock_commit_msg() { gh api "repos/$CRQ_REPO/git/commits/$1" --jq '.message // empty' 2>/dev/null; }
# Returns the lock commit SHA, or nothing if the ref is absent. NOTE: `gh api` dumps
# the error body to stdout and skips --jq on HTTP 404, so we must validate that the
# output is actually a 40-char hex sha (else a missing ref looks "held").
_lock_ref_sha() {
  local out
  out="$(gh api "repos/$CRQ_REPO/git/refs/heads/$CRQ_LOCK_REF" --jq '.object.sha // empty' 2>/dev/null)"
  case "$out" in *[!0-9a-f]*|"") return 0 ;; esac
  printf '%s' "$out"
}

# Read the acquire-epoch we embed in the lock commit message (our format, one fetch).
_lock_epoch() { printf '%s' "$1" | sed -n 's/.*epoch=\([0-9][0-9]*\).*/\1/p'; }

acquire() {   # echoes nonce on success
  local nonce msg sha cur hmsg hepoch tries=0 backoff=1
  nonce="$(uuidgen)"
  while [ "$tries" -lt "$CRQ_LOCK_TRIES" ]; do
    tries=$(( tries + 1 ))
    cur="$(_lock_ref_sha)"
    if [ -z "$cur" ]; then
      # ref is free: create our lock commit (acquire epoch embedded for TTL) and claim it
      msg="crq-lock host=$CRQ_HOST pid=$$ nonce=$nonce epoch=$(now)"
      sha="$(gh api -X POST "repos/$CRQ_REPO/git/commits" -f message="$msg" -f tree="$EMPTY_TREE" --jq .sha 2>/dev/null)"
      if [ -n "$sha" ] && gh api -X POST "repos/$CRQ_REPO/git/refs" \
           -f ref="refs/heads/$CRQ_LOCK_REF" -f sha="$sha" >/dev/null 2>&1; then
        cur="$(_lock_ref_sha)"
        if [ -n "$cur" ] && _lock_commit_msg "$cur" | grep -q "nonce=$nonce"; then
          echo "$nonce"; return 0
        fi
      fi
    else
      # held: steal only if demonstrably stale; delete AT MOST ONCE then retry
      # (ownership is proven by the nonce read-back above, so a steal race is safe).
      hmsg="$(_lock_commit_msg "$cur")"; hepoch="$(_lock_epoch "$hmsg")"
      if [ -n "$hepoch" ] && [ $(( $(now) - hepoch )) -gt "$CRQ_LOCK_TTL" ]; then
        log "stealing stale lock (age $(( $(now) - hepoch ))s > ${CRQ_LOCK_TTL}s)"
        gh api -X DELETE "repos/$CRQ_REPO/git/refs/heads/$CRQ_LOCK_REF" >/dev/null 2>&1
        continue
      fi
    fi
    # exponential backoff with jitter — disperses a thundering herd so losers don't
    # hammer the write API into secondary rate limits (which would starve everyone).
    sleep "${backoff}.$(printf '%02d' $(( RANDOM % 100 )))"
    backoff=$(( backoff * 2 )); [ "$backoff" -gt "$CRQ_LOCK_BACKOFF_MAX" ] && backoff="$CRQ_LOCK_BACKOFF_MAX"
  done
  return 1
}

release() {   # $1 = nonce; only deletes if we still own it
  local cur
  cur="$(_lock_ref_sha)" || return 0
  [ -n "$cur" ] || return 0
  if _lock_commit_msg "$cur" | grep -q "nonce=$1"; then
    gh api -X DELETE "repos/$CRQ_REPO/git/refs/heads/$CRQ_LOCK_REF" >/dev/null 2>&1
  fi
}

# ----------------------------------------------------------------------------
# State (JSON inside the dashboard issue body, between markers).
# ----------------------------------------------------------------------------
empty_state() {
  jq -cn --arg scope "$CRQ_SCOPE" \
    '{v:1,rev:0,next_seq:0,queue:[],in_flight:null,last_fired:null,warn:null,fired:{},history:[],
      blocked:{scope:$scope,blocked_until:null,remaining:null,source:"init",checked_at:null,calib_asked_at:null}}'
}

state_read() {   # echoes compact JSON from the dashboard issue
  need CRQ_REPO; need CRQ_ISSUE
  gh api "repos/$CRQ_REPO/issues/$CRQ_ISSUE" --jq .body 2>/dev/null \
    | sed -n "/$STATE_BEGIN/,/$STATE_END/p" | sed '1d;$d' | jq -c . 2>/dev/null
}

render_human() {
  TZ="${CRQ_TZ:-UTC}" jq -r '
    def ts(x): if x==null then "—" else (x | fromdateiso8601 | strflocaltime("%Y-%m-%d %H:%M %Z")) end;
    def link(repo; pr): "[\(repo)#\(pr)](https://github.com/\(repo)/pull/\(pr))";
    def mins(x): ((x | fromdateiso8601) - now) / 60 | floor;
    (if (.blocked.blocked_until != null) and ((.blocked.blocked_until | fromdateiso8601) > now)
       then "🔴 Blocked — next review in ~\(mins(.blocked.blocked_until))m"
     elif (.in_flight != null) then "🟡 Reviewing \(.in_flight.repo)#\(.in_flight.pr)"
     elif ((.queue | length) > 0) then "🟡 \(.queue|length) queued"
     else "🟢 Idle — all caught up" end) as $status |
    "# 🐰 crq — CodeRabbit review queue",
    "",
    "### \($status)",
    "",
    "|   |   |",
    "|---|---|",
    "| **Scope** | `\(.blocked.scope // "—")` |",
    "| **Reviews remaining** | \(if .blocked.remaining != null then (.blocked.remaining|tostring) elif (.blocked.blocked_until != null and ((.blocked.blocked_until|fromdateiso8601) > now)) then "0 — rate-limited" else "available now" end)  _(via \(.blocked.source // "—"))_ |",
    "| **Rate limit** | \(if (.blocked.blocked_until != null and ((.blocked.blocked_until|fromdateiso8601) > now)) then "⛔ resets \(ts(.blocked.blocked_until)) (~\(mins(.blocked.blocked_until))m)" else "✅ not currently limited" end) |",
    "| **Last review fired** | \(ts(.last_fired)) |",
    "| **In flight** | \(if .in_flight==null then "—" else "\(link(.in_flight.repo; .in_flight.pr)) · fired \(ts(.in_flight.fired_at)) · `\(.in_flight.by_host)`" end) |",
    (if (.warn // null) != null then "", "> ⚠️ \(.warn)" else empty end),
    "",
    "## ⏳ Queue — \(.queue|length) waiting",
    "",
    (if (.queue|length)==0 then "_Nothing queued._"
     else ("| # | PR | enqueued | host |", "|--:|---|---|---|"),
          (.queue | sort_by(.seq) | to_entries[] |
            "| \(.key + 1) | \(link(.value.repo; .value.pr)) | \(ts(.value.enqueued_at)) | `\(.value.host)` |")
     end),
    "",
    "## ✅ Recently reviewed — last \((.history // []) | length)",
    "",
    (if ((.history // []) | length)==0 then "_None yet._"
     else ("| PR | commit | reviewed | host |", "|---|---|---|---|"),
          ((.history // [])[] |
            "| \(link(.repo; .pr)) | `\(.commit // "?")` | \(ts(.at)) | `\(.host)` |")
     end),
    "",
    "---",
    "<sub>🤖 Managed by [crq](https://github.com/kristofferR/coderabbit-queue) · rev \(.rev) · updated \(ts(.wrote_at)) · do not edit by hand (machine state is in the hidden block at the top).</sub>"
  ' <<<"$1"
}

render_title() {
  jq -r '
    (if (.blocked.blocked_until!=null) and ((.blocked.blocked_until|fromdateiso8601)>now) then "🔴 blocked"
     elif .in_flight!=null then "🟡 reviewing #\(.in_flight.pr)"
     elif (.queue|length)>0 then "🟡 \(.queue|length) queued"
     else "🟢 idle" end) as $s |
    "crq · \($s) · queue \(.queue|length)"
  ' <<<"$1"
}

state_write() {   # $1 = JSON; bumps rev, stamps wrote_at, re-renders issue
  local json body title
  json="$(jq -c --arg now "$(now_iso)" '.rev=((.rev//0)+1) | .wrote_at=$now' <<<"$1")"
  body="$(printf '%s\n%s\n%s\n\n%s\n' "$STATE_BEGIN" "$(jq -c . <<<"$json")" "$STATE_END" "$(render_human "$json")")"
  title="$(render_title "$json")"
  printf '%s' "$body" | gh issue edit "$CRQ_ISSUE" --repo "$CRQ_REPO" --title "$title" --body-file - >/dev/null
}

# ----------------------------------------------------------------------------
# Rate-limit signal: active calibration (primary) + WARNING scan (corroboration)
# ----------------------------------------------------------------------------

# Post the rate-limit command on the calibration PR (records the ask time).
_calib_post() {
  gh api "repos/$CRQ_REPO/issues/$CRQ_CAL_PR/comments" -f body="$CRQ_RATELIMIT_CMD" --jq .created_at 2>/dev/null
}

# Latest bot rate-limit *reply* on the calibration PR with updated_at > $1 (ISO).
# Filters to the reply marker so it ignores the PR-open summary/skip comment.
_calib_latest_reply() {
  gh api "repos/$CRQ_REPO/issues/$CRQ_CAL_PR/comments" --paginate \
    --jq "[.[]|select(.user.login==\"$CRQ_BOT\")|select(.body|contains(\"$CRQ_CAL_REPLY_MARKER\"))|select(.updated_at > \"$1\")]|last|{u:.updated_at,b:.body}" 2>/dev/null
}

# Parse a CodeRabbit reply/body for (remaining, reset_epoch). Tolerant; refined
# at rollout once the exact wording is confirmed. Echoes "remaining|reset_epoch"
# (either side may be empty).
parse_quota() {
  local text="$1" base="$2" remaining="" reset=""
  # Only count explicit "N reviews remaining/left" — never "available in N" (that's a countdown).
  remaining="$(printf '%s' "$text" | grep -oiE '[0-9]+ +review[s]? +(remaining|left)' | grep -oE '[0-9]+' | head -1)"
  [ -z "$remaining" ] && remaining="$(printf '%s' "$text" | grep -oiE '(reviews? +remaining|remaining)[: ]+[0-9]+' | grep -oE '[0-9]+' | head -1)"
  reset="$(parse_available_in "$text" "$base")"
  echo "${remaining}|${reset}"
}

# Refresh .blocked in $1 (JSON). Calibration (asking CodeRabbit directly) is the
# AUTHORITATIVE, primary signal; a stale WARNING comment on some PR must never
# override a fresh "available now" reply. The open-PR WARNING scan is only a
# fallback used when no fresh calibration reply is available. Echoes updated JSON.
calibrate_json() {
  local json="$1" n checked src reply cutoff rtext rbase pair remaining reset at w wreset bu bu_e
  n="$(now)"
  checked="$(jq -r '.blocked.checked_at // empty' <<<"$json")"
  src="$(jq -r '.blocked.source // empty' <<<"$json")"
  if [ -n "$checked" ] && [ $(( n - $(iso2epoch "$checked") )) -lt "$CRQ_CALIBRATE_TTL" ]; then
    # Trust a recent calibration reading...
    [ "$src" = "calibrate" ] && { echo "$json"; return 0; }
    # ...and a recent WARNING-derived block (e.g. a fired review was just rate-limited) — don't
    # let a stale "available now" calibration override it.
    if [ "$src" = "warning" ]; then
      bu="$(jq -r '.blocked.blocked_until // empty' <<<"$json")"; bu_e=0; [ -n "$bu" ] && bu_e="$(iso2epoch "$bu")"
      [ "$bu_e" -gt "$n" ] && { echo "$json"; return 0; }
    fi
  fi
  if [ -n "${CRQ_CAL_PR:-}" ]; then
    # Reuse a fresh prior reply (avoids spamming the calibration PR).
    cutoff="$(epoch2iso $(( n - CRQ_CALIBRATE_TTL )))"
    reply="$(_calib_latest_reply "$cutoff")"
    if [ -z "$reply" ] || [ "$reply" = "null" ]; then
      at="$(_calib_post)"
      if [ -n "$at" ]; then
        for _ in 1 2 3 4 5 6; do
          sleep 2
          reply="$(_calib_latest_reply "$at")"
          [ -n "$reply" ] && [ "$reply" != "null" ] && break
        done
        [ -z "$reply" ] || [ "$reply" = "null" ] && \
          json="$(jq -c --arg a "$at" '.blocked.calib_asked_at=$a' <<<"$json")"
      fi
    fi
    if [ -n "$reply" ] && [ "$reply" != "null" ]; then
      rtext="$(jq -r .b <<<"$reply")"; rbase="$(iso2epoch "$(jq -r .u <<<"$reply")")"
      pair="$(parse_quota "$rtext" "$rbase")"; remaining="${pair%%|*}"; reset="${pair##*|}"
      json="$(jq -c --arg ca "$(now_iso)" --argjson rem "${remaining:-null}" \
                --arg bu "$([ -n "$reset" ] && epoch2iso "$reset")" \
                '.blocked.source="calibrate" | .blocked.checked_at=$ca | .blocked.remaining=$rem
                 | .blocked.blocked_until=(if $bu=="" then null else $bu end)
                 | .blocked.calib_asked_at=null' <<<"$json")"
      echo "$json"; return 0
    fi
  fi
  # Fallback: most-recently-updated WARNING across the scope (recency, not max).
  w="$(_warning_latest)"
  if [ -n "$w" ]; then
    wreset="${w##*|}"
    json="$(jq -c --arg ca "$(now_iso)" \
              --arg bu "$([ "$wreset" -gt "$n" ] && epoch2iso "$wreset")" \
              '.blocked.source="warning" | .blocked.checked_at=$ca | .blocked.remaining=null
               | .blocked.blocked_until=(if $bu=="" then null else $bu end)' <<<"$json")"
  else
    json="$(jq -c --arg ca "$(now_iso)" \
              '.blocked.source="none" | .blocked.checked_at=$ca
               | .blocked.blocked_until=null | .blocked.remaining=null' <<<"$json")"
  fi
  echo "$json"
}

# Most-recently-updated CodeRabbit WARNING across the scope's open PRs.
# Echoes "updated_epoch|reset_epoch" or nothing.
_warning_latest() {
  [ "$CRQ_WARNING_SCAN" = "1" ] || return 1
  local owner repo num line u b ue reset best_u=0 best_reset=0 found=0
  for owner in ${CRQ_SCOPE//,/ }; do
    while read -r repo num; do
      [ -n "$repo" ] || continue
      line="$(gh api "repos/$repo/issues/$num/comments" --paginate \
        --jq "[.[]|select(.user.login==\"$CRQ_BOT\")|select(.body|contains(\"$CRQ_RL_MARKER\"))]|last|{u:.updated_at,b:.body}" 2>/dev/null)"
      [ -n "$line" ] && [ "$line" != "null" ] || continue
      u="$(jq -r .u <<<"$line")"; b="$(jq -r .b <<<"$line")"
      ue="$(iso2epoch "$u")"; reset="$(parse_available_in "$b" "$ue")" || continue
      [ -n "$reset" ] || continue
      if [ "$ue" -gt "$best_u" ]; then best_u="$ue"; best_reset="$reset"; found=1; fi
    done < <(gh search prs --owner "$owner" --state open --json number,repository \
               --jq '.[]|"\(.repository.nameWithOwner) \(.number)"' 2>/dev/null)
  done
  [ "$found" = "1" ] && echo "${best_u}|${best_reset}"
}

# ----------------------------------------------------------------------------
# In-flight detection: can pump fire the NEXT review?
# Returns 0 (clear) / 1 (still in flight). Echoes a reason on stderr.
# ----------------------------------------------------------------------------
inflight_status() {   # $1 = json; echoes timeout | warning:<reset_epoch> | done ; 0=cleared 1=still in flight
  local inf repo pr fired_at fired_id fe n rx newer wl wu wb wreset
  inf="$(jq -c '.in_flight // empty' <<<"$1")"
  [ -n "$inf" ] || return 0
  repo="$(jq -r .repo <<<"$inf")"; pr="$(jq -r .pr <<<"$inf")"
  fired_at="$(jq -r .fired_at <<<"$inf")"; fired_id="$(jq -r .fired_comment_id <<<"$inf")"
  fe="$(iso2epoch "$fired_at")"; n="$(now)"
  if [ $(( n - fe )) -gt "$CRQ_INFLIGHT_TIMEOUT" ]; then echo "timeout" ; return 0; fi
  # Our fire was rate-limited? CodeRabbit posts a fresh WARNING on this PR — surface its reset
  # so the gate backs off IMMEDIATELY instead of trusting a stale "available now" calibration.
  wl="$(gh api "repos/$repo/issues/$pr/comments" --paginate \
    --jq "[.[]|select(.user.login==\"$CRQ_BOT\")|select(.body|contains(\"$CRQ_RL_MARKER\"))|select(.updated_at > \"$fired_at\")]|last|{u:.updated_at,b:.body}" 2>/dev/null)"
  if [ -n "$wl" ] && [ "$wl" != "null" ]; then
    wu="$(jq -r .u <<<"$wl")"; wb="$(jq -r .b <<<"$wl")"
    wreset="$(parse_available_in "$wb" "$(iso2epoch "$wu")")"
    echo "warning:${wreset:-0}"; return 0
  fi
  rx="$(gh api "repos/$repo/issues/comments/$fired_id/reactions" \
        --jq "[.[]|select(.user.login==\"$CRQ_BOT\")]|length" 2>/dev/null)"
  [ "${rx:-0}" -gt 0 ] && { echo "done"; return 0; }
  newer="$(gh api "repos/$repo/issues/$pr/comments" --paginate \
    --jq "[.[]|select(.user.login==\"$CRQ_BOT\")|select((.id|tostring)!=\"$fired_id\")|select(.updated_at > \"$fired_at\")]|length" 2>/dev/null)"
  [ "${newer:-0}" -gt 0 ] && { echo "done"; return 0; }
  return 1
}

# ----------------------------------------------------------------------------
# gc: drop closed/merged PRs from queue; clear timed-out in-flight.
# ----------------------------------------------------------------------------
gc_json() {   # $1 = json
  local json="$1" entry repo pr state inf reason gat n wreset
  n="$(now)"
  # in-flight: clear as soon as a completion signal appears (responsive — every call).
  inf="$(jq -c '.in_flight // empty' <<<"$json")"
  if [ -n "$inf" ]; then
    reason="$(inflight_status "$json")" && {
      case "$reason" in
        warning:*)
          # the fired review was rate-limited -> back off NOW using the WARNING's countdown
          wreset="${reason#warning:}"
          if [ "${wreset:-0}" -gt "$n" ]; then
            json="$(jq -c --arg bu "$(epoch2iso "$wreset")" --arg ca "$(now_iso)" \
              '.in_flight=null | .warn=null | .blocked.blocked_until=$bu | .blocked.source="warning" | .blocked.remaining=0 | .blocked.checked_at=$ca' <<<"$json")"
            log "rate-limited on fired PR — blocked until $(epoch2iso "$wreset")"
          else
            json="$(jq -c '.in_flight=null | .warn=null' <<<"$json")"
          fi ;;
        timeout)
          json="$(jq -c '.warn="in_flight \(.in_flight.repo)#\(.in_flight.pr) timed out without a completion signal — check detector" | .in_flight=null' <<<"$json")" ;;
        *)
          json="$(jq -c '.in_flight=null | .warn=null' <<<"$json")" ;;
      esac
    }
  fi
  # queue prune (drop non-open PRs): gated by CRQ_GC_TTL — the per-PR scan is costly.
  gat="$(jq -r '.gc_at // empty' <<<"$json")"
  if [ -z "$gat" ] || [ $(( n - $(iso2epoch "$gat") )) -gt "$CRQ_GC_TTL" ]; then
    while read -r entry; do
      [ -n "$entry" ] || continue
      repo="$(jq -r .repo <<<"$entry")"; pr="$(jq -r .pr <<<"$entry")"
      state="$(gh api "repos/$repo/pulls/$pr" --jq '.state // empty' 2>/dev/null)"
      # Only drop on an explicit "closed". A transient API error returns a JSON body on
      # stdout (gh skips --jq on errors), so anything that isn't a known state = keep.
      if [ "$state" = "closed" ]; then
        log "gc: dropping $repo#$pr (closed)"
        json="$(jq -c --arg r "$repo" --argjson p "$pr" --arg k "$repo#$pr" \
          '.queue|=map(select(.repo!=$r or .pr!=$p)) | del(.fired[$k])' <<<"$json")"
      fi
    done < <(jq -c '.queue[]?' <<<"$json")
    json="$(jq -c --arg t "$(now_iso)" '.gc_at=$t' <<<"$json")"
  fi
  echo "$json"
}

# ----------------------------------------------------------------------------
# Subcommands
# ----------------------------------------------------------------------------
cmd_enqueue() {
  local repo="$1" pr="$2" nonce json present
  need CRQ_REPO; need CRQ_ISSUE
  nonce="$(acquire)" || die "could not acquire lock"
  # shellcheck disable=SC2064
  trap "release '$nonce'" EXIT
  json="$(state_read)" || { release "$nonce"; trap - EXIT; die "cannot read state"; }
  present="$(jq --arg r "$repo" --argjson p "$pr" \
    '[ (.queue[]?|select(.repo==$r and .pr==$p)),
       (.in_flight | select(.!=null and .repo==$r and .pr==$p)) ] | length' <<<"$json")"
  if [ "${present:-0}" -eq 0 ]; then
    json="$(jq -c --arg r "$repo" --argjson p "$pr" --arg h "$CRQ_HOST" --arg t "$(now_iso)" --arg o "${repo%%/*}" \
      '.next_seq=((.next_seq//0)+1)
       | .queue += [{seq:.next_seq, owner:$o, repo:$r, pr:$p, host:$h, enqueued_at:$t}]' <<<"$json")"
    state_write "$json"
    log "enqueued $repo#$pr (seq $(jq -r '.next_seq' <<<"$json"))"
  else
    log "$repo#$pr already queued/in-flight"
  fi
  release "$nonce"; trap - EXIT
}

cmd_pump() {
  local nonce json n bu bu_epoch lf lf_epoch qn cfresh infp head repo pr seq cid hsha key lastsha
  need CRQ_REPO; need CRQ_ISSUE

  # Lockless fast path: avoid taking the global lock on idle ticks. Re-checked
  # under the lock below, so a wrong skip just waits for the next tick.
  json="$(state_read)" || die "cannot read state"
  n="$(now)"
  bu_epoch=0; bu="$(jq -r '.blocked.blocked_until // empty' <<<"$json")"; [ -n "$bu" ] && bu_epoch="$(iso2epoch "$bu")"
  cfresh=0
  if [ "$(jq -r '.blocked.source // empty' <<<"$json")" = "calibrate" ]; then
    local ck; ck="$(jq -r '.blocked.checked_at // empty' <<<"$json")"
    [ -n "$ck" ] && [ $(( n - $(iso2epoch "$ck") )) -lt "$CRQ_CALIBRATE_TTL" ] && cfresh=1
  fi
  qn="$(jq '.queue|length' <<<"$json")"
  infp="$(jq -r 'if .in_flight==null then 0 else 1 end' <<<"$json")"
  if [ "$cfresh" = "1" ] && { [ "$n" -lt "$bu_epoch" ] || { [ "$qn" -eq 0 ] && [ "$infp" = "0" ]; }; }; then
    return 0   # blocked (and known), or idle with nothing to do — no lock needed
  fi

  nonce="$(acquire)" || die "could not acquire lock"
  # shellcheck disable=SC2064
  trap "release '$nonce'" EXIT
  json="$(state_read)" || { release "$nonce"; trap - EXIT; die "cannot read state"; }

  json="$(gc_json "$json")"          # clears in_flight when a completion signal appears
  json="$(calibrate_json "$json")"

  n="$(now)"
  bu="$(jq -r '.blocked.blocked_until // empty' <<<"$json")"; bu_epoch=0
  [ -n "$bu" ] && bu_epoch="$(iso2epoch "$bu")"
  lf="$(jq -r '.last_fired // empty' <<<"$json")"; lf_epoch=0
  [ -n "$lf" ] && lf_epoch="$(iso2epoch "$lf")"
  qn="$(jq '.queue|length' <<<"$json")"
  infp="$(jq -r 'if .in_flight==null then 0 else 1 end' <<<"$json")"   # post-gc

  if [ "$n" -lt "$bu_epoch" ]; then
    log "blocked for $(( bu_epoch - n ))s (until $bu, source $(jq -r .blocked.source <<<"$json"))"
  elif [ "$infp" = "1" ]; then
    log "waiting: review in flight ($(jq -r '.in_flight.repo' <<<"$json")#$(jq -r '.in_flight.pr' <<<"$json"))"
  elif [ $(( n - lf_epoch )) -lt "$CRQ_MIN_INTERVAL" ]; then
    log "min-interval: $(( CRQ_MIN_INTERVAL - (n - lf_epoch) ))s to go"
  elif [ "$qn" -eq 0 ]; then
    log "queue empty"
  else
    # window open, nothing in flight, interval ok, queue non-empty -> fire FIFO head
    head="$(jq -c '.queue|sort_by(.seq)|.[0]' <<<"$json")"
    repo="$(jq -r .repo <<<"$head")"; pr="$(jq -r .pr <<<"$head")"; seq="$(jq -r .seq <<<"$head")"
    hsha="$(gh api "repos/$repo/pulls/$pr" --jq '.head.sha // empty' 2>/dev/null | cut -c1-9)"
    key="$repo#$pr"
    lastsha="$(jq -r --arg k "$key" '.fired[$k] // empty' <<<"$json")"
    if [ -n "$hsha" ] && [ "$hsha" = "$lastsha" ]; then
      # DEDUP: we already requested a review for this exact commit (e.g. autoreview and an
      # agent both queued it). Drop it without posting a second @coderabbitai review.
      json="$(jq -c --argjson s "$seq" '.queue|=map(select(.seq!=$s))' <<<"$json")"
      log "dedup: review already requested for $key@$hsha — not re-posting"
    elif [ "${CRQ_DRY_RUN:-0}" = "1" ]; then
      log "DRY-RUN: would fire $CRQ_REVIEW_CMD on $repo#$pr@${hsha:-?} (seq $seq)"
      state_write "$json"; release "$nonce"; trap - EXIT; return 0
    else
      cid="$(gh api "repos/$repo/issues/$pr/comments" -f body="$CRQ_REVIEW_CMD" --jq .id 2>/dev/null)"
      if [ -n "$cid" ]; then
        json="$(jq -c --argjson s "$seq" --arg r "$repo" --argjson p "$pr" \
                  --arg fa "$(now_iso)" --argjson cid "$cid" --arg h "$CRQ_HOST" \
                  --arg k "$key" --arg hs "$hsha" \
          '.queue|=map(select(.seq!=$s))
           | .in_flight={seq:$s,repo:$r,pr:$p,fired_at:$fa,fired_comment_id:$cid,by_host:$h}
           | .last_fired=$fa | .warn=null
           | (if $hs=="" then . else .fired[$k]=$hs end)
           | .history = ([{repo:$r,pr:$p,commit:(if $hs=="" then null else $hs end),at:$fa,host:$h}] + (.history // []))[0:20]' <<<"$json")"
        log "FIRED $repo#$pr@${hsha:-?} (seq $seq, comment $cid)"
      else
        log "failed to post review command on $repo#$pr"
      fi
    fi
  fi

  state_write "$json"
  release "$nonce"; trap - EXIT
}

cmd_wait() {
  local repo="$1" pr="$2" start json queued
  need CRQ_REPO; need CRQ_ISSUE
  cmd_enqueue "$repo" "$pr"
  start="$(now)"
  while true; do
    cmd_pump >/dev/null 2>&1 || true
    json="$(state_read)" || { sleep "$CRQ_POLL"; continue; }
    queued="$(jq --arg r "$repo" --argjson p "$pr" '[.queue[]?|select(.repo==$r and .pr==$p)]|length' <<<"$json")"
    if [ "${queued:-1}" -eq 0 ]; then
      log "fired $repo#$pr"; return 0
    fi
    if [ "$CRQ_WAIT_TIMEOUT" -gt 0 ] && [ $(( $(now) - start )) -gt "$CRQ_WAIT_TIMEOUT" ]; then
      log "wait timeout for $repo#$pr"; return 2
    fi
    sleep $(( CRQ_POLL + (RANDOM % 5) ))
  done
}

cmd_status() {
  local json; need CRQ_REPO; need CRQ_ISSUE
  json="$(state_read)" || die "cannot read state"
  render_human "$json"
}

cmd_cancel() {
  local repo="$1" pr="$2" nonce json
  nonce="$(acquire)" || die "could not acquire lock"
  # shellcheck disable=SC2064
  trap "release '$nonce'" EXIT
  json="$(state_read)" || { release "$nonce"; trap - EXIT; die "cannot read state"; }
  json="$(jq -c --arg r "$repo" --argjson p "$pr" \
    '.queue|=map(select(.repo!=$r or .pr!=$p))
     | (if (.in_flight!=null and .in_flight.repo==$r and .in_flight.pr==$p) then .in_flight=null else . end)' <<<"$json")"
  state_write "$json"
  release "$nonce"; trap - EXIT
  log "cancelled $repo#$pr"
}

cmd_gc() {
  local nonce json
  nonce="$(acquire)" || die "could not acquire lock"
  # shellcheck disable=SC2064
  trap "release '$nonce'" EXIT
  json="$(state_read)" || { release "$nonce"; trap - EXIT; die "cannot read state"; }
  json="$(gc_json "$json")"; state_write "$json"
  release "$nonce"; trap - EXIT
}

cmd_refresh() {
  local nonce json
  nonce="$(acquire)" || die "could not acquire lock"
  # shellcheck disable=SC2064
  trap "release '$nonce'" EXIT
  json="$(state_read)" || { release "$nonce"; trap - EXIT; die "cannot read state"; }
  json="$(jq -c '.blocked.checked_at=null' <<<"$json")"   # force re-calibrate
  json="$(calibrate_json "$json")"; state_write "$json"
  release "$nonce"; trap - EXIT
  cmd_status
}

cmd_unlock() {
  local cur msg hepoch age
  cur="$(_lock_ref_sha)"
  if [ -z "$cur" ]; then log "no lock held"; return 0; fi
  msg="$(_lock_commit_msg "$cur")"; hepoch="$(_lock_epoch "$msg")"
  if [ -n "$hepoch" ]; then age="$(( $(now) - hepoch ))s"; else age="?"; fi
  log "current holder: ${msg:-<unknown>} (age $age)"
  if [ "${1:-}" = "--force" ]; then
    gh api -X DELETE "repos/$CRQ_REPO/git/refs/heads/$CRQ_LOCK_REF" >/dev/null 2>&1 && log "lock deleted"
  else
    log "pass --force to delete"
  fi
}

cmd_init() {
  need CRQ_REPO
  local owner branch base_sha pr_url issue_url
  owner="${CRQ_REPO%%/*}"
  if ! gh repo view "$CRQ_REPO" >/dev/null 2>&1; then
    log "creating private repo $CRQ_REPO"
    gh repo create "$CRQ_REPO" --private --add-readme \
      -d "crq gate — CodeRabbit review queue lock + dashboard (managed by crq)" >/dev/null
    sleep 2
  fi
  # .coderabbit.yaml on default branch: never auto-review this repo
  if ! gh api "repos/$CRQ_REPO/contents/.coderabbit.yaml" >/dev/null 2>&1; then
    log "committing .coderabbit.yaml (auto-review disabled)"
    gh api -X PUT "repos/$CRQ_REPO/contents/.coderabbit.yaml" \
      -f message="crq: disable auto-review (calibration repo)" \
      -f content="$(printf 'reviews:\n  auto_review:\n    enabled: false\n  high_level_summary: false\n' | base64)" >/dev/null
    sleep 1
  fi
  # calibration draft PR (a trivial branch with one file so a PR can exist)
  if [ -z "${CRQ_CAL_PR:-}" ] || ! gh pr view "$CRQ_CAL_PR" --repo "$CRQ_REPO" >/dev/null 2>&1; then
    base_sha="$(gh api "repos/$CRQ_REPO/git/refs/heads/$(gh api repos/$CRQ_REPO --jq .default_branch)" --jq .object.sha)"
    branch="crq/calibration"
    gh api -X POST "repos/$CRQ_REPO/git/refs" -f ref="refs/heads/$branch" -f sha="$base_sha" >/dev/null 2>&1 || true
    gh api "repos/$CRQ_REPO/contents/CALIBRATION.md?ref=$branch" >/dev/null 2>&1 || \
      gh api -X PUT "repos/$CRQ_REPO/contents/CALIBRATION.md" -f branch="$branch" \
        -f message="crq: calibration thread" \
        -f content="$(printf '# crq calibration\n\nThis PR exists only so crq can post `@coderabbitai rate limit` here\nto read the account-wide quota without consuming a review. Do not merge.\n' | base64)" >/dev/null
    pr_url="$(gh pr create --repo "$CRQ_REPO" --base "$(gh api repos/$CRQ_REPO --jq .default_branch)" \
      --head "$branch" --draft --title "crq calibration (do not merge)" \
      --body "crq posts \`$CRQ_RATELIMIT_CMD\` here to read account-wide CodeRabbit quota. Auto-review is disabled for this repo." 2>/dev/null)"
    CRQ_CAL_PR="$(printf '%s' "$pr_url" | grep -oE '[0-9]+$')"
    log "calibration PR: ${pr_url:-#$CRQ_CAL_PR}"
  fi
  # dashboard issue
  if [ -z "${CRQ_ISSUE:-}" ] || ! gh issue view "$CRQ_ISSUE" --repo "$CRQ_REPO" >/dev/null 2>&1; then
    local json body
    json="$(empty_state)"
    body="$(printf '%s\n%s\n%s\n\n%s\n' "$STATE_BEGIN" "$json" "$STATE_END" "$(render_human "$json")")"
    issue_url="$(printf '%s' "$body" | gh issue create --repo "$CRQ_REPO" \
      --title "crq: q=0 · idle · remaining=?" --body-file - 2>/dev/null)"
    CRQ_ISSUE="$(printf '%s' "$issue_url" | grep -oE '[0-9]+$')"
    log "dashboard issue: ${issue_url:-#$CRQ_ISSUE}"
  fi
  printf '\n# Add these to %s (or your shell profile):\n' "${CRQ_CONFIG:-$HOME/.config/crq/env}"
  printf 'export CRQ_REPO=%q\n'  "$CRQ_REPO"
  printf 'export CRQ_ISSUE=%q\n' "$CRQ_ISSUE"
  printf 'export CRQ_CAL_PR=%q\n' "$CRQ_CAL_PR"
  printf 'export CRQ_SCOPE=%q\n' "$CRQ_SCOPE"
}

# Emulate CodeRabbit's native auto-review (+ incremental review), but rate-coordinated:
# enqueue open PRs in scope that need a review, then let the FIFO pump fire them when the
# account is unblocked. Keep CodeRabbit's own auto-review OFF so this is the only driver.
#   default          : auto-review + incremental — review new PRs AND re-review on every push
#                      (enqueue whenever HEAD isn't the last CRQ_BOT-reviewed commit)
#   --no-incremental : auto-review only — review each PR once (when it has no review yet),
#                      never re-review on later pushes
#   --once           : single pass (e.g. from cron / a monitor); otherwise loops forever
cmd_autoreview() {
  local once=0 incremental=1 a
  for a in "$@"; do case "$a" in
    --once) once=1 ;; --no-incremental) incremental=0 ;;
    *) die "usage: crq autoreview [--once] [--no-incremental]" ;;
  esac; done
  need CRQ_REPO; need CRQ_ISSUE
  local owner repo pr head crrev json present key firedsha
  while true; do
    json="$(state_read 2>/dev/null)" || json=""
    for owner in ${CRQ_SCOPE//,/ }; do
      while read -r repo pr; do
        [ -n "$repo" ] || continue
        [ "$repo" = "$CRQ_REPO" ] && continue   # never auto-review the gate repo (calibration PR)
        # repo allowlist / denylist (comma-separated owner/name; allowlist empty = all in scope)
        if [ -n "$CRQ_REPOS" ]; then case ",$CRQ_REPOS," in *",$repo,"*) ;; *) continue ;; esac; fi
        if [ -n "$CRQ_EXCLUDE" ]; then case ",$CRQ_EXCLUDE," in *",$repo,"*) continue ;; esac; fi
        key="$repo#$pr"
        # skip PRs already queued / in-flight (lockless pre-check avoids lock churn)
        if [ -n "$json" ]; then
          present="$(jq --arg r "$repo" --argjson p "$pr" \
            '[ (.queue[]?|select(.repo==$r and .pr==$p)),
               (.in_flight|select(.!=null and .repo==$r and .pr==$p)) ]|length' <<<"$json" 2>/dev/null)"
          [ "${present:-0}" -gt 0 ] && continue
        fi
        head="$(gh api "repos/$repo/pulls/$pr" --jq '.head.sha // empty' 2>/dev/null | cut -c1-9)"
        [ -n "$head" ] || continue
        # DEDUP: skip if we already requested a review for this exact commit (pump records it).
        firedsha="$(jq -r --arg k "$key" '.fired[$k] // empty' <<<"${json:-{}}" 2>/dev/null)"
        [ "$firedsha" = "$head" ] && continue
        crrev="$(gh api "repos/$repo/pulls/$pr/reviews" \
          --jq "map(select(.user.login==\"$CRQ_BOT\" and .commit_id!=null))|last|.commit_id // \"\"" 2>/dev/null | cut -c1-9)"
        if [ "$incremental" = "0" ]; then
          [ -z "$crrev" ] && cmd_enqueue "$repo" "$pr"          # auto-review only: never reviewed yet
        else
          [ "$crrev" != "$head" ] && cmd_enqueue "$repo" "$pr"  # + incremental: HEAD not yet reviewed
        fi
      done < <(gh search prs --owner "$owner" --state open --json number,repository \
                 --jq '.[]|"\(.repository.nameWithOwner) \(.number)"' 2>/dev/null)
    done
    cmd_pump >/dev/null 2>&1 || true
    [ "$once" = "1" ] && break
    sleep "$CRQ_AUTOREVIEW_POLL"
  done
}

usage() {
  cat >&2 <<EOF
crq — CodeRabbit review queue (account-wide coordinator for parallel agents)

USAGE
  crq init                      provision the gate repo (lock, dashboard issue, calibration PR)
  crq wait    <repo> <pr>       enqueue and block until OUR review is fired (use this in loops)
  crq autoreview [--once] [--no-incremental]
                               emulate CodeRabbit auto-review (+ incremental) review, rate-coordinated:
                               enqueue open PRs needing review; loops unless --once.
                               --no-incremental = review each PR once only (no re-review on push)
  crq enqueue <repo> <pr>       add to the FIFO queue (idempotent)
  crq pump                      fire <=1 queued review if the window is open (safe to call anywhere)
  crq calibrate                 refresh the account-wide rate-limit reading
  crq status                    show the dashboard
  crq cancel  <repo> <pr>       remove from queue / clear if stuck in-flight
  crq gc                        drop closed PRs; clear timed-out in-flight
  crq refresh                   force a fresh calibration and print status
  crq unlock  [--force]         inspect / break the global lock
  crq version                   print the crq version
  crq help                      show this help

<repo> is owner/name; <pr> is a number. Configure via env / \$HOME/.config/crq/env
(CRQ_REPO is required). See 'crq init' output and the README.
EOF
}

main() {
  local cmd="${1:-}"; shift || true
  # These need nothing — handle before the gh/jq/auth preflight.
  case "$cmd" in
    ""|-h|--help|help)     usage; return 0 ;;
    -v|--version|version)  echo "crq $CRQ_VERSION"; return 0 ;;
  esac
  # Everything else needs gh + jq, and an authenticated gh.
  command -v gh >/dev/null 2>&1 || die "gh (GitHub CLI) is required — install: https://cli.github.com/"
  command -v jq >/dev/null 2>&1 || die "jq is required — install: https://jqlang.github.io/jq/"
  gh auth token >/dev/null 2>&1 || die "gh is not logged in — run: gh auth login"
  case "$cmd" in
    init)      cmd_init "$@" ;;
    enqueue)   [ $# -eq 2 ] || die "usage: crq enqueue <repo> <pr>"; cmd_enqueue "$@" ;;
    pump)      cmd_pump ;;
    wait)      [ $# -eq 2 ] || die "usage: crq wait <repo> <pr>"; cmd_wait "$@" ;;
    autoreview) cmd_autoreview "$@" ;;
    calibrate) cmd_refresh ;;
    status)    cmd_status ;;
    cancel)    [ $# -eq 2 ] || die "usage: crq cancel <repo> <pr>"; cmd_cancel "$@" ;;
    gc)        cmd_gc ;;
    refresh)   cmd_refresh ;;
    unlock)    cmd_unlock "${1:-}" ;;
    *) die "unknown command: $cmd (try 'crq help')" ;;
  esac
}
main "$@"
